# Nuxt Session Password (minimum 32 caractères)
# Généré automatiquement par Nuxt Auth Utils au premier démarrage si non défini
NUXT_SESSION_PASSWORD=

# GitHub OAuth Configuration
# Créez une OAuth App sur GitHub: https://github.com/settings/developers
# Callback URL: http://localhost:3000/auth/github (ou votre domaine en production)
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
